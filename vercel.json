{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "redirects": [
    {
      "source": "/mobile",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/mobile.html",
      "destination": "/",
      "permanent": true
    }
  ]
}
